{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hushline",
  "version": "0.1.0",
  "identifier": "com.hushline.stt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Hushline", "width": 1240, "height": 820, "minWidth": 920, "minHeight": 680, "resizable": true, "center": true, "decorations": true, "backgroundColor": "#0b0d0a" }],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": [] }
}
